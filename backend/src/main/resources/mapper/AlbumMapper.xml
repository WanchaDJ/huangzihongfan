<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yupi.yuoj.mapper.AlbumMapper">

    <resultMap id="BaseResultMap" type="com.yupi.yuoj.model.entity.Album">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="title" column="title" jdbcType="VARCHAR"/>
        <result property="artist" column="artist" jdbcType="VARCHAR"/>
        <result property="coverImage" column="coverImage" jdbcType="VARCHAR"/>
        <result property="releaseYear" column="releaseYear" jdbcType="INTEGER"/>
        <result property="type" column="type" jdbcType="VARCHAR"/>
        <result property="trackCount" column="trackCount" jdbcType="INTEGER"/>
        <result property="description" column="description" jdbcType="VARCHAR"/>
        <result property="playCount" column="playCount" jdbcType="INTEGER"/>
        <result property="createTime" column="createTime" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="updateTime" jdbcType="TIMESTAMP"/>
        <result property="isDelete" column="isDelete" jdbcType="TINYINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,title,artist,coverImage,
        releaseYear,type,trackCount,description,
        playCount,createTime,updateTime,isDelete
    </sql>

</mapper>
